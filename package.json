{
  "name": "authz-sandbox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "fix": "npm run lint:fix && npm run format:fix",
    "dev": "npm run cf-typegen && vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test": "run-s test:frontend test:unit test:e2e",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:frontend": "vitest run --config vitest.config.frontend.ts",
    "test:unit:cov": "vitest run --config vitest.config.unit.ts --coverage",
    "test:e2e:cov": "vitest run --config vitest.config.e2e.ts --coverage",
    "db:gen": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply authz-sandbox --local",
    "db:reset:local": "vite-node -c vite.seed-cli.config.ts worker/cli/run-local-reset.ts",
    "db:seed:local": "vite-node -c vite.seed-cli.config.ts worker/cli/run-local-seed.ts",
    "db:reset:seed": "npm run db:migrate:local && npm run db:reset:local && npm run db:seed:local",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.2",
    "ulidx": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@cloudflare/vite-plugin": "^1.31.0",
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@cloudflare/workers-types": "^4.20260503.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "globals": "^16.5.0",
    "happy-dom": "^20.8.9",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-node": "^3.2.4",
    "vitest": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.5",
    "wrangler": "^4.80.0"
  }
}
